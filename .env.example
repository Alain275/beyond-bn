# Server
PORT=4000

# JWT signing secret (change in production)
JWT_SECRET=replace-with-a-strong-secret

# PostgreSQL
# Optional full connection string (if set, this is used instead of host/port/user/pass)
# DATABASE_URL=postgres://postgres:password@localhost:5432/beyond

DB_HOST=localhost
DB_PORT=5432
DB_NAME=beyond
DB_USER=postgres
DB_PASSWORD=replace-with-db-password
DB_SSL=false

# Cloudinary (required for /api/articles/upload-image)
# Option 1: single URL from Cloudinary dashboard
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Option 2: separate credentials
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
