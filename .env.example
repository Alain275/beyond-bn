# Server
PORT=4000

# JWT signing secret (change in production)
JWT_SECRET=replace-with-a-strong-secret

# PostgreSQL
# Optional full connection string (if set, this is used instead of host/port/user/pass)
# DATABASE_URL=postgres://postgres:password@localhost:5432/beyond

DB_HOST=localhost
DB_PORT=5432
DB_NAME=beyond
DB_USER=postgres
DB_PASSWORD=replace-with-db-password
DB_SSL=false
